{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationDir": "./dist",
		"emitDeclarationOnly": true,
		"rootDir": "./src"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "src/__tests__"]
}
